# Production Caddyfile — HTTP only (port 80 inside container)
:80 {
    # Security headers
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        X-XSS-Protection "1; mode=block"
        Referrer-Policy "strict-origin-when-cross-origin"
        -Server
    }

    # Gzip compression
    encode gzip

    # API routes -> backend service (rewrite /api/* to /api/v1/*)
    handle /api/* {
        uri replace /api/ /api/v1/ 1
        reverse_proxy api:3000
    }

    # All other routes -> frontend service
    handle {
        reverse_proxy web:80
    }

    # Health endpoint for the proxy itself
    handle /health {
        respond "OK" 200
    }
}
